          "inputs": ["SQLite projects table", "state.json", "reference-data override", "2_開挖擋土支撐-v95000.xlsm", "imported files", "report outputs"],
          "calculation": ["ProjectStore", "save_project", "save_imported_file", "save_report", "load_reference_data", "save_reference_data", "_sanitize_reference_data", "load_default_project"],
